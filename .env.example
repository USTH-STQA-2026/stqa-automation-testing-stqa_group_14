# Copy file này thành .env rồi điền thông tin thật
# cp .env.example .env

# URL hệ thống cần test
BASE_URL=https://stqa.rbc.vn

# Tài khoản test - đăng nhập thành công
TEST_EMAIL=your_email@example.com
TEST_PASSWORD=your_password

# Tên hiển thị sau khi đăng nhập (dùng để assert)
TEST_DISPLAY_NAME=Tên người dùng

# Tài khoản thành viên bị tạm ngưng - dùng cho test_suspended_borrow
SUSPENDED_EMAIL=suspended_member@example.com
SUSPENDED_PASSWORD=your_password

# Tài khoản thành viên hết hạn - dùng cho test_expired_borrow
EXPIRED_EMAIL=expired_member@example.com
EXPIRED_PASSWORD=your_password
